# Database (PostgreSQL — run `docker compose up -d` first)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/predictflow"

# Auth - generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret"
AUTH_TRUST_HOST=true

# OAuth - Google (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OAuth - Kakao (https://developers.kakao.com/)
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# OpenAI (optional - AI analysis will use fallback without this)
# OPENAI_API_KEY="sk-..."

# Telegram Bot (create via https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""

# Discord Bot (create via https://discord.com/developers)
DISCORD_APP_ID=""
DISCORD_BOT_TOKEN=""
DISCORD_PUBLIC_KEY=""
